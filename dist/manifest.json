{
  "manifest_version": 3,
  "name": "NotebookLM Companion",
  "version": "1.0.0",
  "description": "Organize your NotebookLM notebooks with folders, tags, colors, favorites, notes, and smart views.",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://notebooklm.google.com/*"
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": ["content.js"],
      "css": ["companion.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "NotebookLM Companion",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },

  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}

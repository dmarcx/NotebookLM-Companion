{
  "name": "notebooklm-companion",
  "version": "1.0.0",
  "description": "Chrome extension to organize NotebookLM notebooks with folders, tags, colors, and more.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "icons": "node scripts/create-icons.mjs",
    "prebuild": "node scripts/create-icons.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.290",
    "esbuild": "^0.24.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0"
  }
}
